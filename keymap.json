[
  //panel
  { "bindings": { "alt-a": "agent::ToggleFocus" } },
  { "bindings": { "alt-s": "project_panel::Toggle" } },
  { "bindings": { "alt-d": "outline_panel::ToggleFocus" } },
  //delete
  {
    "context": "ProjectPanel",
    "bindings": { "delete": ["project_panel::Trash", { "skip_prompt": true }] },
  },
  //run
  {
    "context": "(Editor && extension == py)",
    "bindings": { "f5": ["task::Spawn", { "task_name": "Run Python" }] },
  },
  {
    "context": "(Editor && extension == ps1)",
    "bindings": { "f5": ["task::Spawn", { "task_name": "Run pwsh" }] },
  },
  //fold
  {
    "context": "Editor",
    "bindings": { "alt-w": "editor::Fold", "alt-e": "editor::UnfoldLines" },
  },
  //search
  {
    "context": "Pane",
    "bindings": { "f3": "search::SelectPreviousMatch" },
  },
  //wrap
  {
    "context": "Editor",
    "bindings": { "alt-z": "editor::ToggleSoftWrap" },
  },
  //preview
  {
    "context": "Editor && (extension == md || extension == svg)",
    "bindings": { "alt-v": "markdown::OpenPreviewToTheSide" },
  },
  //terminal
  {
    "context": "Workspace",
    "bindings": { "ctrl-t": "terminal_panel::Toggle" },
  },
  {
    "context": "Terminal",
    "bindings": { "ctrl-w": "pane::CloseActiveItem" },
  },
]
