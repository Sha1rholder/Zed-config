{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Test themes",
  "author": "Zed Industries",
  "description": "Test themes",
  "themes": [
    {
      "name": "empty dark",
      "appearance": "dark",
      "style": {}
    },
    {
      "name": "polycarbonate dark",
      "appearance": "dark",
      "style": {
        //background
        "background.appearance": "transparent",
        "background": "#000D",
        "editor.background": "#0000",
        "editor.gutter.background": "#0000",
        "terminal.background": "#0000",

        //top to bottom
        "title_bar.background": "#000D",
        "tab_bar.background": "#0000",
        "tab.active_background": "#000",
        "tab.inactive_background": "#0000",
        "toolbar.background": "#0000",
        "status_bar.background": "#000D",

        //panel
        "panel.background": "#0000",
        "element.selected": "#FFFFFF19",
        "element.background": "#FFFFFF19",
        "editor.active_line.background": "#FFFFFF19",
        "ghost_element.selected": "#FFFFFF19",
        "ghost_element.hover": "#FFFFFF19",
        "ghost_element.active": "#FFFFFF19",

        //surface
        "elevated_surface.background": "#000D",
        "surface.background": "#FFFFFF19",

        //pop-up
        "error.background": "#000D",
        "warning.background": "#000D",

        //git
        "created": "#0F0B",
        "deleted": "#F00B",
        "modified": "#FF0B",

        //scrollbar
        "scrollbar.track.border": "#0000",
        "scrollbar.thumb.background": "#FFF3",
        "scrollbar.thumb.hover_background": "#FFF4",

        //search
        "search.match_background": "#333",
        "search.active_match_background": "#666",

        //forground
        "editor.invisible": "#555",
        "predictive": "#57A"
      }
    }
  ]
}
